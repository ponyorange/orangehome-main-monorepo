# Core HTTP API (existing)
CORE_SERVICE_HTTP_URL=http://localhost:3000

# Port (optional)
PORT=4000

# Login password transport (RSA-OAEP-256 + AES-256-GCM)
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Use multiline PEM or single line with \n escaped in .env
LOGIN_RSA_PRIVATE_KEY_PEM=
LOGIN_RSA_KEY_ID=dev-key-1

# When true, POST /api/auth/login accepts plain { email, password } for local debugging only.
# MUST be false in production.
ALLOW_PLAIN_PASSWORD_LOGIN=false
