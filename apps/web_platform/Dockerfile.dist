# 精简版：仅打包已构建的 dist，不拉取 node 镜像
# 使用方式：先在本地执行 rush build，再构建镜像
#
#   rush build -t @orangehome/web_platform
#   docker build -f apps/web_platform/Dockerfile.dist -t orangehome/web_platform:latest .

FROM docker.m.daocloud.io/library/nginx:alpine

COPY apps/web_platform/dist /usr/share/nginx/html
COPY apps/web_platform/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
