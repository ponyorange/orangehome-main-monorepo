# 运行时预览页 URL 模板，须包含字面量 `{pageId}`（构建时注入）
# 示例（请按部署环境修改主机与路径）：
# VITE_RUNTIME_PREVIEW_URL_TEMPLATE=http://192.168.1.91:50055/orangehome/runtime/preview/{pageId}

VITE_RUNTIME_PREVIEW_URL_TEMPLATE=

# 仅 HTTP/公网 IP 调试：与 BFF 的 ALLOW_PLAIN_PASSWORD_LOGIN=true 同时开启才允许明文登录；公网生产勿用
# VITE_ALLOW_PLAIN_PASSWORD_LOGIN=true
