{
  "name": "@orangehome/web_builder",
  "version": "0.1.0",
  "description": "Orange Editor - 基于插槽化架构的可视化页面编辑器",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "modern build",
    "build:spa": "vite build --config vite.app.config.ts",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix"
  },
  "dependencies": {
    "@orangehome/password-transport": "workspace:*",
    "@douyinfe/semi-foundation": "^2.40.0",
    "@douyinfe/semi-icons": "^2.40.0",
    "@douyinfe/semi-ui": "^2.40.0",
    "@swc/helpers": "^0.5.0",
    "eventemitter2": "^6.4.9",
    "inversify": "^6.0.1",
    "monaco-editor": "^0.55.1",
    "nanoid": "^5.0.0",
    "reflect-metadata": "^0.1.13",
    "swr": "^2.2.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@modern-js/module-tools": "^2.40.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
