<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' && lang ? String(lang) : 'zh-CN' %>">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- 与 plugins/runtime/src/rem/htmlRootFontSize.ts 一致：首屏 SSR 的 rem 依赖此值；须在解析 #app 前同步执行（勿 defer） -->
  <script>
    (function () {
      var design =
        typeof window.__ORANGEHOME_DESIGN_WIDTH__ === 'number' &&
        window.__ORANGEHOME_DESIGN_WIDTH__ > 0
          ? window.__ORANGEHOME_DESIGN_WIDTH__
          : 750;
      var rootAtDesign = 100;
      var cw = document.documentElement.clientWidth || window.innerWidth;
      if (!cw || cw < 1) cw = 375;
      var w = Math.max(1, Math.min(cw, design));
      document.documentElement.style.fontSize =
        (w / design) * rootAtDesign + 'px';
    })();
  </script>
  <meta name="generator" content="orangehome-server-cside">
  <title>
    <%= typeof pageTitle !=='undefined' && pageTitle ? String(pageTitle) : 'Page' %> | <%= typeof siteName
        !=='undefined' && siteName ? String(siteName) : 'OrangeHome' %>
  </title>
  <!-- 内嵌配置：合法 JSON，供引导脚本读取（勿用非 JSON 语法）。componentsAmdMap 为浏览器 AMD 脚本 URL，与 SSG 运行时一致，便于水合。 -->
  <script type="application/json" id="ORANGEHOME_DATA"><%- JSON.stringify({
    schema: typeof pageSchema !== 'undefined' ? pageSchema : null,
    componentsAmdMap: typeof componentsAmdMap === 'object' && componentsAmdMap !== null ? componentsAmdMap : {}
  }) %></script>
  <script defer src="http://8.148.251.221:6011/orangehome/materials/basic/react/react-18.js"></script>
  <script defer src="http://8.148.251.221:6011/orangehome/materials/basic/react/react-dom-18.js"></script>
  <script defer src="http://8.148.251.221:6011/orangehome/materials/basic/amd_require/require.min.js"></script>
  <!-- 与 plugins/runtime/src/index.css 中 .oh-top-loading-bar 一致；defer 资源未执行前即显示 -->
  <style>
    #oh-pre-react-progress.oh-top-loading-bar{position:fixed;top:0;left:0;right:0;height:3px;z-index:2147483646;pointer-events:none;overflow:hidden;background:rgba(15,23,42,.06)}
    #oh-pre-react-progress .oh-top-loading-bar__inner{height:100%;width:100%;transform-origin:left center;background:linear-gradient(90deg,#3b82f6 0%,#6366f1 45%,#8b5cf6 100%);animation:oh-top-loading-indeterminate 1.1s ease-in-out infinite}
    @keyframes oh-top-loading-indeterminate{0%{transform:translateX(-100%) scaleX(0.35);opacity:1}50%{transform:translateX(10%) scaleX(0.85);opacity:1}100%{transform:translateX(100%) scaleX(0.4);opacity:1}}
  </style>
</head>

<body>
  <div id="oh-pre-react-progress" class="oh-top-loading-bar oh-top-loading-bar--run" aria-hidden="true">
    <div class="oh-top-loading-bar__inner"></div>
  </div>
  <div id="app"><%- typeof ssrHtml === 'string' ? ssrHtml : '' %></div>
  <script defer
    src="http://8.148.251.221:6011/orangehome/materials/@orangehome/common-plugin-ssrruntime/1.0.2/index.js"></script>

  <% const map=(typeof componentsAmdMap==='object' && componentsAmdMap !==null) ? componentsAmdMap : {}; const
    urls=Object.values(map).filter(function (u) { return typeof u==='string' && u.length> 0; });
    const seen = new Set();
    %>
    <% urls.forEach(function (url) { if (seen.has(url)) return; seen.add(url); %>
      <script defer src="<%- url %>"></script>
      <% }); %>

        <% if (typeof pageScripts==='string' && pageScripts.length) { %>
          <%- pageScripts %>
            <% } %>
</body>

</html>
